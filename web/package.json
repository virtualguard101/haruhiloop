{
  "name": "haruhiloop-web",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "description": "Haruhi Loop · 无尽八月循环模拟器 · Web 终端版",
  "scripts": {
    "dev": "npm run bundle:python && vite",
    "build": "npm run bundle:python && tsc --noEmit && vite build",
    "bundle:python": "bash scripts/build-python-bundle.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "pyodide": "^0.27.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
